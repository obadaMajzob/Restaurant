@{
    ViewData["Title"] = "Home Page";
    Layout = "_LayoutPrimary";
}
@model Restaurant.ViewModels.HomeViewModel
<div class="slider-area">
    <div class="slider-active owl-dot-style owl-carousel">
        @foreach (var item in Model.MasterSliderList)
        {

            <div class="single-slider bg-img height-100vh d-flex align-items-center justify-content-center" style="background-image:url('@item.MasterSliderUrl');">
                <div class="slider-content pt-100">
                    <div class="slider-content-wrap slider-animated-1">
                        <h2 class="animated">@Html.Raw(item.MasterSliderTitle)</h2>
                        <h1 class="animated">@Html.Raw(item.MasterSliderBreef)</h1>
                        <p>@item.MasterSliderDesc</p>
                        <div class="slider-btn mt-20">
                            <a class="animated" asp-action="Index" asp-controller="ProductDetails">read more</a>
                        </div>
                    </div>
                </div>
            </div>

        }



