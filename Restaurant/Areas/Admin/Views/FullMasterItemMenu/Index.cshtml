    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@

@model Restaurant.ViewModels.MasterFullItemMenuViewModel
@{
    ViewData["Title"] = "Full Action";
}



<div class="row">
    <div class="col-12">
        <form id="saneForm" asp-action="Save" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Id" class="control-label"></label>
                <input asp-for="Id" class="control-label" value="0" readonly />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MasterItemMenuTitle" class="control-label"></label>
                <input asp-for="MasterItemMenuTitle" class="form-control" />
                <span asp-validation-for="MasterItemMenuTitle" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MasterItemMenuDesc" class="control-label"></label>
                <input asp-for="MasterItemMenuDesc" class="form-control" />
                <span asp-validation-for="MasterItemMenuDesc" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MasterItemMenuPrice" class="control-label"></label>
                <input asp-for="MasterItemMenuPrice" class="form-control" />
                <span asp-validation-for="MasterItemMenuPrice" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MasterItemMenuBreef" class="control-label"></label>
                <input asp-for="MasterItemMenuBreef" class="form-control" />
                <span asp-validation-for="MasterItemMenuBreef" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MasterCategoryMenuId" MasterCategoryMenuId="control-label"></label>
                <select onselect="" asp-for="MasterCategoryMenuId" class="form-control" asp-items="Model.ListOfCategory">
                    <option value="0" selected> No Selected : </option>
                </select>
            </div>


            <div class="form-group">
                <input type="hidden" asp-for="MasterItemMenuImageUrl" class="form-control" />
                @* <input asp-for="CVURL" class="form-control" type="hidden" /> *@
                <label asp-for="MasterItemMenuImageUrl" class="control-label"></label>
                <input asp-for="ImageFile" class="form-control" />
                <span asp-validation-for="MasterItemMenuImageUrl" class="text-danger"></span>
            </div>


            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <input type="button" value="Clear" class="btn btn-dark" onclick="ClearForm()" />
            </div>
        </form>
    </div>
</div>



<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.MasterItemMenuTitle)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MasterItemMenuDesc)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MasterItemMenuPrice)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MasterItemMenuBreef)
            </th>
    
            <th>
                @Html.DisplayNameFor(model => model.MasterCategoryMenuId)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.MasterItemMenuImageUrl)
            </th>

            <th></th>

        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.MasterItemMenuViewModelss)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.MasterItemMenuTitle)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MasterItemMenuDesc)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MasterItemMenuPrice)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MasterItemMenuBreef)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MasterCategoryMenuId)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.MasterItemMenuImageUrl)
                </td>

                <td></td>

                <td>


                    @* fillBtn *@
                    <a href="#" class=" fillBtn btn btn-warning icon-btn b-r-22"
                       data-id="@item.Id"
                       data-title="@item.MasterItemMenuTitle"
                       data-description="@item.MasterItemMenuDesc"
                       data-price="@item.MasterItemMenuPrice"
                       data-brief="@item.MasterItemMenuBreef"
                       data-category="@item.MasterCategoryMenuId"
                       data-imageurl="@item.MasterItemMenuImageUrl">Edit2</a> |

                    @* Delete *@
                    <form asp-action="Delete" id="DeleteForm-@item.Id" class="d-inline">
                        <input type="hidden" asp-for="Id" value="@item.Id " />
                        <input type="button" value="Delete" class="btn btn-danger icon-btn b-r-22" onclick="ConfirmDelete('@item.Id')" />
                    </form>

                    @* Change Status *@
                    @if (item.IsActivate)
                    {
                        <form asp-action="ChangeStatus" id="ChangeForm-@item.Id" class="d-inline">
                            <input type="hidden" asp-for="Id" value="@item.Id " />
                            <input type="button" value="Deavtivate" class="btn btn-danger icon-btn b-r-22" onclick="ConfirmChange('@item.Id')" />
                        </form>
                    }
                    else
                    {
                        <form asp-action="ChangeStatus" id="ChangeForm-@item.Id" class="d-inline">
                            <input type="hidden" asp-for="Id" value="@item.Id " />
                            <input type="button" value="Avtivate" class="btn btn-danger icon-btn b-r-22" onclick="ConfirmChange('@item.Id')" />
                        </form>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>



<script src="~/lib/jquery/dist/jquery.js"></script>
<script src="~/lib/sweetalert2/sweetalert2.all.js"></script>
<script>

    $(function () {

        $(".fillBtn").on("click", function () {
            var Id = $(this).data('id')
            var MasterItemMenuTitle = $(this).data('title')
            var MasterItemMenuDesc = $(this).data('description')
            var MasterItemMenuPrice = $(this).data('price')
            var MasterItemMenuBreef = $(this).data('brief')
            var MasterCategoryMenuId = $(this).data('category')
            var ImageFile = $(this).data('imageurl')


            $("#Id").val(Id);
            $("#MasterItemMenuTitle").val(MasterItemMenuTitle);
            $("#MasterItemMenuDesc").val(MasterItemMenuDesc);
            $("#MasterItemMenuPrice").val(MasterItemMenuPrice);
            $("#MasterItemMenuBreef").val(MasterItemMenuBreef);
            $("#MasterCategoryMenuId").val(MasterCategoryMenuId);
            $("#ImageURL").val(ImageFile);
        })



    })
    function ConfirmDelete(id) {
        Swal.fire({
            title: "Are you sure?",
            text: "You won't be able to revert this!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, delete it!"
        }).then((result) => {
            if (result.isConfirmed) {
                $(`#DeleteForm-${id}`).submit()
            }
        });
    }

    function ConfirmChange(id) {
        Swal.fire({
            title: "Are you sure?",
            text: "You won't be able to revert this!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, Change it!"
        }).then((result) => {
            if (result.isConfirmed) {
                $(`#ChangeForm-${id}`).submit()
            }
            else { }
        });
    }


    function ClearForm() {

        $("#saneForm #Id").val(0);
        $("#MasterItemMenuTitle").val('');
        $("#MasterItemMenuDesc").val('');
        $("#MasterItemMenuPrice").val('');
        $("#MasterItemMenuBreef").val('');
        $("#MasterCategoryMenuId").val('');
        $("#ImageURL").val('');

    }
</script>







